{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 8,
  "modules-left": ["clock"],
  "modules-center": ["wlr/taskbar"],
  "modules-right": ["power-profiles-daemon", "pulseaudio", "network", "tray"],

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "icon-theme": "Adwaita",
    "spacing": 4,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "cursor": false,
  },

  "clock": {
    "format": "{:%H:%M ︱ %a %d %b}",
    "tooltip": true,
    "tooltip-format": "{:%A, %d %B %Y}"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip": true,
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    },
    "interval": 1
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰖁 muted",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "on-click": "pavucontrol",
    "tooltip": true
  },
  "network": {
    "format-wifi": "󰤨 {signalStrength}%",
    "format-ethernet": "󰈀 wired",
    "format-disconnected": "󰤭 offline",
    "tooltip": true
  },
  "tray": {
    "spacing": 8
  }
}
